#!/bin/bash
# /usr/bin/froxlor-setup
# Interaktives Setup-Skript für Froxlor nach der Installation

set -e

FROXLOR_DIR="/var/www/froxlor"
ENV_FILE="$FROXLOR_DIR/.env"
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'

if [ "$(id -u)" != "0" ]; then
    echo -e "${RED}Fehler: Dieses Skript muss als root ausgeführt werden.${NC}"
    echo "Nutze: sudo froxlor-setup"
    exit 1
fi

echo ""
echo -e "${CYAN}${BOLD}Froxlor v3 — Setup-Assistent${NC}"
echo -e "${CYAN}════════════════════════════${NC}"
echo ""

# --- Datenbank-Konfiguration ---
echo -e "${YELLOW}Datenbank-Konfiguration${NC}"
echo ""

read -p "Datenbank-Typ [mysql/pgsql/sqlite] (Standard: mysql): " DB_CONNECTION
DB_CONNECTION=${DB_CONNECTION:-mysql}

if [ "$DB_CONNECTION" != "sqlite" ]; then
    read -p "Datenbank-Host (Standard: 127.0.0.1): " DB_HOST
    DB_HOST=${DB_HOST:-127.0.0.1}

    read -p "Datenbank-Port (Standard: 3306): " DB_PORT
    DB_PORT=${DB_PORT:-3306}

    read -p "Datenbank-Name (Standard: froxlor): " DB_DATABASE
    DB_DATABASE=${DB_DATABASE:-froxlor}

    read -p "Datenbank-Benutzer (Standard: froxlor): " DB_USERNAME
    DB_USERNAME=${DB_USERNAME:-froxlor}

    read -s -p "Datenbank-Passwort: " DB_PASSWORD
    echo ""
fi

# --- .env aktualisieren ---
echo ""
echo -e "${CYAN}Konfiguration wird gespeichert...${NC}"

if [ "$DB_CONNECTION" != "sqlite" ]; then
    sed -i "s|^DB_CONNECTION=.*|DB_CONNECTION=${DB_CONNECTION}|" "$ENV_FILE"
    sed -i "s|^DB_HOST=.*|DB_HOST=${DB_HOST}|" "$ENV_FILE"
    sed -i "s|^DB_PORT=.*|DB_PORT=${DB_PORT}|" "$ENV_FILE"
    sed -i "s|^DB_DATABASE=.*|DB_DATABASE=${DB_DATABASE}|" "$ENV_FILE"
    sed -i "s|^DB_USERNAME=.*|DB_USERNAME=${DB_USERNAME}|" "$ENV_FILE"
    sed -i "s|^DB_PASSWORD=.*|DB_PASSWORD=${DB_PASSWORD}|" "$ENV_FILE"
fi

sed -i "s|^APP_ENV=.*|APP_ENV=production|" "$ENV_FILE"
sed -i "s|^APP_DEBUG=.*|APP_DEBUG=false|" "$ENV_FILE"

read -p "App-URL (Standard: http://$(hostname -I | awk '{print $1}')): " APP_URL
APP_URL=${APP_URL:-http://$(hostname -I | awk '{print $1}')}
sed -i "s|^APP_URL=.*|APP_URL=${APP_URL}|" "$ENV_FILE"

# --- Migrationen ausführen ---
echo ""
echo -e "${CYAN}Datenbanktabellen werden erstellt...${NC}"
sudo -u www-data php "$FROXLOR_DIR/artisan" migrate --force

# --- Cache leeren und neu aufbauen ---
echo -e "${CYAN}Cache wird optimiert...${NC}"
sudo -u www-data php "$FROXLOR_DIR/artisan" config:cache
sudo -u www-data php "$FROXLOR_DIR/artisan" route:cache
sudo -u www-data php "$FROXLOR_DIR/artisan" view:cache

# --- Admin-Account erstellen ---
echo ""
echo -e "${YELLOW}Administrator-Account erstellen${NC}"
echo ""
read -p "Name des Administrators (Standard: Administrator): " ADMIN_NAME
ADMIN_NAME=${ADMIN_NAME:-Administrator}

read -p "E-Mail-Adresse: " ADMIN_EMAIL
while [ -z "$ADMIN_EMAIL" ]; do
    echo -e "${RED}E-Mail darf nicht leer sein.${NC}"
    read -p "E-Mail-Adresse: " ADMIN_EMAIL
done

read -s -p "Passwort (mind. 8 Zeichen): " ADMIN_PASSWORD
echo ""
while [ ${#ADMIN_PASSWORD} -lt 8 ]; do
    echo -e "${RED}Passwort muss mind. 8 Zeichen lang sein.${NC}"
    read -s -p "Passwort: " ADMIN_PASSWORD
    echo ""
done

sudo -u www-data php "$FROXLOR_DIR/artisan" froxlor:create-admin \
    --name="$ADMIN_NAME" \
    --email="$ADMIN_EMAIL" \
    --password="$ADMIN_PASSWORD"

# --- Queue Worker starten ---
echo ""
echo -e "${CYAN}Queue Worker wird gestartet...${NC}"
systemctl start froxlor-queue.service 2>/dev/null || true

# --- Fertig ---
echo ""
echo -e "${GREEN}${BOLD}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}${BOLD}║            Setup erfolgreich abgeschlossen!      ║${NC}"
echo -e "${GREEN}${BOLD}╚══════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${CYAN}Admin-Panel:${NC}  ${APP_URL}/admin"
echo -e "  ${CYAN}Login:${NC}        ${ADMIN_EMAIL}"
echo ""
echo -e "${YELLOW}Vergiss nicht, den Webserver zu konfigurieren:${NC}"
echo "  Apache: cp /etc/froxlor/apache.conf.example /etc/apache2/sites-available/froxlor.conf"
echo "  Nginx:  cp /etc/froxlor/nginx.conf.example /etc/nginx/sites-available/froxlor"
echo ""
